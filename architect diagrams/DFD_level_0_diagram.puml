@startuml RealTimeGestureControl_DFD_Level0

!define PROCESS_COLOR #90CAF9
!define ENTITY_COLOR #A5D6A7
!define DATASTORE_COLOR #FFE082

left to right direction

''' External Entities
rectangle "User" as USER <<entity>> #A5D6A7
rectangle "Webcam\nInput" as WEBCAM <<entity>> #A5D6A7
rectangle "Operating System\nCursor Control" as OS <<entity>> #A5D6A7
rectangle "Display\nMonitor" as DISPLAY <<entity>> #A5D6A7

''' Main System Process
circle "Real-Time\nGesture Control\nSystem" as SYSTEM #90CAF9

''' Data Flows
WEBCAM --> SYSTEM: 1. Video Stream\n(640×480, 30 FPS)
SYSTEM --> OS: 2. Cursor Actions\n(move, click, drag, scroll)
USER --> SYSTEM: 3. Control Commands\n(start/stop, config)
SYSTEM --> DISPLAY: 4. Debug Output\n(gesture, confidence, FPS)
OS -.-> SYSTEM: 5. Cursor Feedback\n(position confirmation)

note right of WEBCAM
  Real-time input
  640×480 resolution
  30 FPS frame rate
end note

note right of SYSTEM
  Core Processing Loop
  
  1. Hand Detection (MediaPipe)
  2. ROI Extraction
  3. Image Preprocessing
  4. ViT Inference
  5. Gesture Classification
  6. Debouncing
  7. Cursor Smoothing
  8. Action Execution
  
  Target Latency: <100ms
  Throughput: 30 FPS
end note

note right of OS
  System cursor control
  Move/Click/Drag/Scroll
  PyAutoGUI interface
end note

note right of DISPLAY
  Debug visualization
  - Gesture name
  - Confidence score
  - FPS counter
  - Hand landmarks
  - Bounding box
end note

note right of USER
  Manual interaction
  - Start/stop system
  - Configure parameters
  - Toggle debug mode
end note

@enduml