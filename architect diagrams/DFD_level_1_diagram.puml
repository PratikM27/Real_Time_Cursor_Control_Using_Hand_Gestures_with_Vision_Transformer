@startuml RealTimeGestureControl_DFD_Level1

!define PROCESS_COLOR #90CAF9
!define ENTITY_COLOR #A5D6A7
!define DATASTORE_COLOR #FFE082

left to right direction

''' External Entities
rectangle "User" as USER <<entity>> #A5D6A7
rectangle "Webcam" as WEBCAM <<entity>> #A5D6A7
rectangle "OS Cursor" as OS <<entity>> #A5D6A7
rectangle "Display" as DISPLAY <<entity>> #A5D6A7

''' Data Stores
rectangle "Configuration\nDB" as CONFIG_DS <<datastore>> #FFE082
rectangle "Model\nCheckpoint\nDB" as MODEL_DS <<datastore>> #FFE082
rectangle "Results\nDB" as RESULTS_DS <<datastore>> #FFE082

''' Sub-processes
circle "1.0\nCapture &\nDetect Hand" as P1 #90CAF9
circle "2.0\nPreprocess\nImage" as P2 #90CAF9
circle "3.0\nRun ViT\nInference" as P3 #90CAF9
circle "4.0\nValidate\nGesture" as P4 #90CAF9
circle "5.0\nSmooth &\nExecute Action" as P5 #90CAF9
circle "6.0\nDisplay\nDebug Info" as P6 #90CAF9

''' Data Flows from External Entities
WEBCAM --> P1: 1a. Video Frame\n(640×480, BGR)
USER --> P1: 1b. Camera Config
CONFIG_DS --> P1: 1c. Detection Params\n(confidence, padding)

''' Data Flow P1 to P2
P1 --> P2: 2a. Hand ROI\n(bbox, landmarks)
CONFIG_DS --> P2: 2b. Preprocessing Config\n(size, normalization)

''' Data Flow P2 to P3
P2 --> P3: 3a. Normalized Tensor\n(1, 3, 224, 224)
MODEL_DS --> P3: 3b. ViT Model\nWeights

''' Data Flow P3 to P4
P3 --> P4: 4a. Logits\n(1, 7 classes)
CONFIG_DS --> P4: 4c. Debounce Params\n(threshold, cooldown)

''' Data Flow P4 to P5
P4 --> P5: 5a. Valid Gesture\n(class_name, confidence)
P1 --> P5: 5b. Hand Center\n(norm_x, norm_y)
CONFIG_DS --> P5: 5c. Smoothing Params\n(window_size)

''' Data Flow P5 to Outputs
P5 --> OS: 5d. Cursor Action\n(move, click, drag, scroll)
P5 --> RESULTS_DS: 5e. Action Log\n(gesture, timestamp)

''' Data Flow to Debug Display
P1 --> P6: 6a. Hand Landmarks
P4 --> P6: 6b. Gesture & Confidence
P5 --> P6: 6c. FPS, Latency
P6 --> DISPLAY: 6d. Debug Overlay\n(annotated frame)

''' Data Flow back to User
DISPLAY --> USER: Feedback\n(real-time visualization)

note right of P1
  HandDetector (MediaPipe)
  
  Inputs:
  - Webcam frame
  - Detection confidence
  
  Outputs:
  - Hand landmarks (21 keypoints)
  - Bounding box (bbox)
  - Hand center position
  
  Processing:
  - Convert BGR→RGB
  - MediaPipe inference
  - Extract landmarks
  - Compute bbox
end note

note right of P2
  Image Preprocessor
  
  Inputs:
  - Hand ROI
  - Preprocess config
  
  Outputs:
  - Normalized tensor
  - (1, 3, 224, 224)
  
  Processing:
  - Extract ROI from bbox
  - Resize to 224×224
  - Normalize (ImageNet)
  - Convert to tensor
end note

note right of P3
  ViT Model Inference
  
  Inputs:
  - Preprocessed tensor
  - Model weights
  
  Outputs:
  - Logits (1, 7)
  - Probabilities
  
  Processing:
  - ViT forward pass
  - Softmax activation
  - ~40-50ms latency
end note

note right of P4
  Gesture Validation
  
  Inputs:
  - Model logits
  - Debounce config
  
  Outputs:
  - Valid gesture flag
  - Gesture class
  - Confidence score
  
  Processing:
  - Argmax prediction
  - Filter confidence
  - Check frame consistency
  - Check click cooldown
end note

note right of P5
  Cursor Smoothing & Action
  
  Inputs:
  - Valid gesture
  - Hand center
  - Smoothing config
  
  Outputs:
  - Cursor action
  - Action log
  
  Processing:
  - Apply moving average
  - Map gesture to action
  - Execute via PyAutoGUI
end note

note right of P6
  Debug Visualization
  
  Inputs:
  - Hand landmarks
  - Gesture info
  - Performance metrics
  
  Outputs:
  - Annotated frame
  
  Processing:
  - Draw landmarks
  - Draw bounding box
  - Draw gesture label
  - Display FPS counter
end note

note right of CONFIG_DS
  Configuration Storage
  
  Contains:
  - VIT_CONFIG
  - MEDIAPIPE settings
  - AUGMENTATION params
  - REALTIME settings
  - Gesture mappings
end note

note right of MODEL_DS
  Model Checkpoint
  
  Contains:
  - best_vit_model.pth
  - Model state_dict
  - Optimizer state
  - Training metadata
end note

note right of RESULTS_DS
  Results Storage
  
  Contains:
  - Action logs
  - Performance metrics
  - Inference times
end note

@enduml