@startuml RealTimeGestureControl_SystemArchitecture

!define EXTERNAL_COLOR #FFE0B2
!define CORE_COLOR #C8E6C9
!define SERVICE_COLOR #BBDEFB
!define DATA_COLOR #F8BBD0
!define IO_COLOR #E1BEE7

top to bottom direction

''' External Actors and Systems
cloud "External Services" as EXT <<external>> #FFE0B2 {
  component [MediaPipe\n(Hand Detection)] as MP
  component [PyTorch\n(DL Framework)] as PT
  component [timm\n(ViT Models)] as TIMM
  component [OpenCV\n(Image Proc)] as CV
  component [PyAutoGUI\n(Cursor Control)] as PYAGUI
  component [scikit-learn\n(Metrics)] as SK
}

''' Input Sources
actor User as U
component [Webcam\nInput Stream] as WC <<input>> #E1BEE7

''' Main Application System
package "Real-Time Gesture Control System" as SYSTEM #C8E6C9 {
  
  package "Initialization Layer" {
    component [Config Manager] as CFG
    component [Model Loader] as ML
    component [Device Detector] as DD
  }
  
  package "Real-Time Pipeline" {
    component [Webcam Capture] as CAPTURE
    component [Hand Detector] as HD
    component [ROI Extractor] as ROI
    component [Image Preprocessor] as PREP
    component [ViT Model\nInference] as VIT
    component [Gesture Classifier] as GC
    component [Confidence Filter] as CF
    component [Gesture Debouncer] as DB
    component [Cursor Smoother] as CS
    component [Cursor Controller] as CC
    component [Action Executor] as AE
  }
  
  package "Training & Evaluation" {
    component [Data Collector] as DC
    component [Dataset Preparer] as DP
    component [Training Engine] as TRAIN
    component [Model Evaluator] as EVAL
    component [RealTime Evaluator] as REVAL
  }
  
  package "Analysis & Reporting" {
    component [Metrics Analyzer] as MA
    component [Report Generator] as RG
    component [Visualizer] as VIZ
  }
  
}

''' Data Storage
package "Data & Storage Layer" as STORAGE #F8BBD0 {
  database [Raw Data\nraw_data/] as RAW_DB
  database [Dataset\ngesture_dataset/] as DATASET_DB
  database [Checkpoints\nbest_vit_model.pth] as CHECKPOINT_DB
  database [Results\n(JSON + PNG)] as RESULTS_DB
}

''' Output Systems
package "Output & Feedback" as OUTPUT #E1BEE7 {
  component [Monitor\nDebug Display] as MON
  component [OS Cursor\nControl] as OSC
}

''' Configuration
component [config.py\nHyperparameters] as CONFIG <<config>> #FFFFCC

''' Connections from External
MP --|> HD: hand landmarks
PT --|> VIT: PyTorch tensors
TIMM --|> VIT: ViT backbone
CV --|> CAPTURE: frame capture
CV --|> PREP: image ops
PYAGUI --|> AE: cursor commands
SK --|> EVAL: metrics
SK --|> REVAL: metrics

''' Input Flow
U --> DC: gesture capture
U --> TRAIN: start training
U --> REVAL: live evaluation
WC --> CAPTURE: video stream
CAPTURE --> HD: frames

''' Real-Time Pipeline Flow
HD --> ROI: landmarks & bbox
ROI --> PREP: cropped ROI
PREP --> VIT: normalized tensor
VIT --> GC: logits
GC --> CF: gesture & confidence
CF --> DB: high confidence
DB --> CS: valid gesture
CS --> CC: smoothed position
CC --> AE: action type
AE --> OSC: cursor command
AE --> MON: action executed

''' Training Flow
DC --> RAW_DB: save images
RAW_DB --> DP: load raw images
DP --> DATASET_DB: stratified split
DATASET_DB --> TRAIN: batches
TRAIN --> CHECKPOINT_DB: save model
TRAIN --> RESULTS_DB: training metrics

''' Evaluation Flow
CHECKPOINT_DB --> EVAL: load model
DATASET_DB --> EVAL: test set
EVAL --> RESULTS_DB: eval results
CHECKPOINT_DB --> REVAL: load model
REVAL --> RESULTS_DB: live results

''' Analysis Flow
RESULTS_DB --> MA: load metrics
MA --> RG: compute stats
RG --> VIZ: generate plots
VIZ --> MON: display report

''' Configuration
CONFIG -.-> CFG: parameters
CONFIG -.-> VIT: model config
CONFIG -.-> CAPTURE: camera settings
CONFIG -.-> DB: debounce settings
CONFIG -.-> CS: smoothing settings
CONFIG -.-> TRAIN: training params

''' Monitor Display
MON --> U: feedback
OSC --> U: cursor control

note right of SYSTEM
  Real-Time Processing Loop
  Target: 30 FPS
  Latency Budget: <100ms
  
  Pipeline:
  1. Capture (10ms)
  2. Detection (10ms)
  3. Preprocess (5ms)
  4. Inference (40-50ms)
  5. Debounce (<1ms)
  6. Smooth (<1ms)
  7. Execute (<1ms)
end note

note right of STORAGE
  File-Based Persistence
  No SQL database
  
  Images: JPEG/PNG
  Checkpoints: PyTorch .pth
  Metrics: JSON
  Plots: PNG
end note

note right of EXT
  Third-Party Libraries
  - MediaPipe: Hand detection
  - PyTorch: Deep learning
  - timm: ViT models
  - OpenCV: Image processing
  - PyAutoGUI: Cursor control
  - scikit-learn: Metrics
end note

@enduml