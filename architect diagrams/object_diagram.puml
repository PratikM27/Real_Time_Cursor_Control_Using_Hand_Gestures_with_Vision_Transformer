@startuml RealTimeGestureControl_ObjectDiagram

!define INSTANCE_COLOR #E3F2FD

object gesture_control_system {
  device = "cuda" | "cpu"
  enable_cursor = true
  show_debug = true
  input_size = 224
  class_names = [7 gesture classes]
  checkpoint_path = "checkpoints/best_vit_model.pth"
}

object vit_model {
  model_name = "vit_tiny_patch16_224"
  num_classes = 7
  pretrained = true
  dropout = 0.1
  total_params = "5.7M"
  model_size_mb = 1.4
}

object hand_detector {
  max_num_hands = 1
  min_detection_confidence = 0.7
  min_tracking_confidence = 0.5
  roi_padding = 20
  detected = true
  landmarks_count = 21
}

object cursor_controller {
  screen_width = 1920
  screen_height = 1080
  scroll_amount = 30
  is_dragging = false
  failsafe = true
}

object cursor_smoother {
  window_size = 5
  x_history = [5 positions]
  y_history = [5 positions]
  smooth_x = 960.0
  smooth_y = 540.0
}

object gesture_debouncer {
  debounce_frames = 2
  click_cooldown_ms = 200
  confidence_threshold = 0.6
  frame_count = 2
  last_click_time = 1234567890
}

object fps_counter {
  fps = 30.0
  frame_count = 150
  start_time = 1234567890.0
  running = true
}

object webcam_input {
  camera_id = 0
  width = 640
  height = 480
  fps = 30
  is_open = true
  current_frame = "numpy array (480,640,3)"
}

object detected_gesture {
  gesture_name = "open_palm"
  confidence = 0.95
  class_id = 0
  timestamp = 1234567890.123
}

object hand_roi {
  bbox = (100, 150, 350, 400)
  center = (0.32, 0.41)
  index_tip = (0.35, 0.38)
  roi_image = "numpy array (250,250,3)"
}

object preprocessed_tensor {
  shape = (1, 3, 224, 224)
  dtype = "torch.float32"
  device = "cuda:0"
  normalized = true
  mean = [0.485, 0.456, 0.406]
  std = [0.229, 0.224, 0.225]
}

object cursor_action {
  action_type = "move_cursor"
  x = 960
  y = 540
  timestamp = 1234567890.150
  executed = true
}

object training_config {
  model_name = "vit_tiny_patch16_224"
  batch_size = 16
  learning_rate = 1e-4
  weight_decay = 1e-4
  epochs = 30
  freeze_epochs = 5
  optimizer = "adamw"
  scheduler = "cosine"
}

object augmentation_config {
  horizontal_flip_prob = 0.5
  rotation_degrees = 15
  color_jitter_brightness = 0.3
  color_jitter_contrast = 0.3
  gaussian_blur_prob = 0.2
  random_crop_scale = "(0.85, 1.0)"
}

object dataset_split {
  train_ratio = 0.70
  val_ratio = 0.15
  test_ratio = 0.15
  train_samples = 1050
  val_samples = 225
  test_samples = 225
  total_samples = 1500
}

object evaluation_results {
  accuracy = 0.92
  precision = 0.91
  recall = 0.92
  f1_score = 0.915
  avg_latency_ms = 45.3
  fps = 22.1
  model_size_mb = 1.4
  total_params = 5700000
}

''' Instance Relationships
gesture_control_system *-- vit_model : loads
gesture_control_system *-- hand_detector : creates
gesture_control_system *-- cursor_controller : creates
gesture_control_system *-- cursor_smoother : creates
gesture_control_system *-- gesture_debouncer : creates
gesture_control_system *-- fps_counter : creates

gesture_control_system -- webcam_input : captures from
hand_detector -- webcam_input : processes
hand_detector -- hand_roi : extracts
webcam_input -- detected_gesture : produces

hand_roi -- preprocessed_tensor : transforms
vit_model -- preprocessed_tensor : receives
vit_model -- detected_gesture : outputs

detected_gesture -- gesture_debouncer : validates
gesture_debouncer -- cursor_action : permits
cursor_smoother -- cursor_action : smooths
cursor_controller -- cursor_action : executes

gesture_control_system -- training_config : uses
gesture_control_system -- augmentation_config : uses
gesture_control_system -- dataset_split : loads from
gesture_control_system -- evaluation_results : logs

vit_model -- training_config : configured by
vit_model -- evaluation_results : produces

note bottom of gesture_control_system
  Runtime Instance
  Main Pipeline Coordinator
  30 FPS real-time loop
end note

note bottom of vit_model
  ViT-Tiny Model Instance
  Loaded from checkpoint
  224×224 input, 7 outputs
end note

note bottom of detected_gesture
  Inference Output
  Single prediction
  Gesture class + confidence
end note

note bottom of cursor_action
  Output Action
  Executed via PyAutoGUI
  Move, click, drag, or scroll
end note

note bottom of evaluation_results
  Evaluation Metrics
  Offline test set performance
  92% accuracy achieved
end note

@enduml