@startuml RealTimeGestureControl_ActivityDiagram

start

:Initialize System;
:Load ViT Model Checkpoint;
:Create HandDetector (MediaPipe);
:Create CursorController;
:Create CursorSmoother;
:Create GestureDebouncer;

while (System Running)
  :Capture Webcam Frame;
  note right
    640×480 @ 30 FPS
  end note
  
  :HandDetector.detect(frame);
  
  if (Hand Landmarks Detected?) then
    :Extract Hand ROI;
    :Compute Bounding Box;
    :Get Hand Center Position;
    
    :Preprocess ROI;
    :Resize to 224×224;
    :Normalize (ImageNet Stats);
    :Create Tensor;
    
    :ViT.predict();
    :Extract Gesture & Confidence;
    
    if (Confidence >= 0.6?) then
      :Check GestureDebouncer;
      
      if (Frame Consistency Valid?) then
        :CursorSmoother.smooth();
        note right
          5-frame moving average
        end note
        
        if (Gesture == open_palm) then
          :CursorController.move_cursor();
        elseif (Gesture == index_point) then
          :CursorController.left_click();
        elseif (Gesture == two_fingers_up) then
          :CursorController.right_click();
        elseif (Gesture == pinch) then
          :CursorController.start_drag();
        elseif (Gesture == three_fingers_up) then
          :CursorController.scroll_up();
        elseif (Gesture == three_fingers_down) then
          :CursorController.scroll_down();
        else
          note right
            fist = neutral
          end note
        endif
      endif
    endif
  else
    note right
      Hand not detected
      Skip prediction
    end note
  endif
  
  :Update FPS Counter;
  
  if (Show Debug Mode?) then
    :Draw Debug Overlay;
    note right
      Gesture name, confidence, FPS
      Hand landmarks, bounding box
    end note
  endif
  
  :Render Frame to Display;
  
  if (Quit Signal Received?) then
    break
  endif
endwhile

:Cleanup & Close Webcam;

end

@enduml