@startuml RealTimeGestureControl_ComponentDiagram

!define EXTERNAL_COLOR #FFE0B2
!define CORE_COLOR #C8E6C9
!define SERVICE_COLOR #BBDEFB
!define IO_COLOR #F8BBD0

package "Data Layer" {
  component [Data Collection] as DC
  component [Dataset Preparation] as DP
  component [ImageFolder Loader] as IFL
}

package "Model Layer" {
  component [GestureViT Model] as MODEL
  component [timm (ViT Backbone)] as TIMM
}

package "Detection & Preprocessing" {
  component [Hand Detector] as HD
  component [ROI Extractor] as ROI
  component [Image Preprocessor] as PREP
}

package "Inference Pipeline" {
  component [Gesture Classifier] as GC
  component [Confidence Filter] as CF
  component [Gesture Debouncer] as DB
}

package "Output Control" {
  component [Cursor Smoother] as CS
  component [Cursor Controller] as CC
  component [PyAutoGUI Interface] as PYAGUI
}

package "Real-Time System" {
  component [GestureControlSystem] as RTS
  component [Webcam Capture] as WC
  component [Debug Visualizer] as DV
}

package "Training & Evaluation" {
  component [Training Pipeline] as TRAIN
  component [Model Evaluation] as EVAL
  component [RealTime Evaluation] as REVAL
  component [Training Utilities] as UTIL
}

package "Analysis & Reporting" {
  component [Report Generator] as REPORT
  component [Metrics Loader] as ML
}

package "Configuration" {
  component [Config Manager] as CONFIG
}

package "External Dependencies" {
  component [MediaPipe] as MP
  component [PyTorch] as PT
  component [OpenCV] as CV
  component [scikit-learn] as SK
  component [Matplotlib/Seaborn] as PLOT
}

''' Data Flow
DC --> DP: raw images
DP --> IFL: stratified splits
IFL --> TRAIN: batches

TRAIN --> MODEL: trains/updates
UTIL --> TRAIN: callbacks, metrics
TRAIN --> UTIL: logs data

''' Model Loading
CONFIG --> MODEL: hyperparameters
MODEL --> TIMM: uses backbone
TIMM --> PT: PyTorch tensors

''' Real-Time Pipeline
WC --> HD: webcam frames
HD --> ROI: hand landmarks
ROI --> PREP: cropped ROI
PREP --> GC: normalized tensor

GC --> CF: (gesture, confidence)
CF --> DB: confidence check
DB --> RTS: valid gesture

''' Gesture to Action
RTS --> CS: hand position
CS --> CC: smoothed coordinates
CC --> PYAGUI: cursor commands
PYAGUI --> CC: execution feedback

''' Evaluation Flow
MODEL --> EVAL: test predictions
IFL --> EVAL: test set
EVAL --> REPORT: metrics
REVAL --> REPORT: live metrics
ML --> REPORT: results loading
REPORT --> PLOT: visualization

''' Integration Points
RTS --> MODEL: inference
RTS --> CONFIG: settings
RTS --> DV: overlay rendering
WC --> CONFIG: camera settings
HD --> MP: hand detection
EVAL --> SK: confusion matrix
PLOT --> EVAL: results
PLOT --> REVAL: results

''' Visualization
DV --> CV: frame drawing
GC --> DV: gesture info
CF --> DV: confidence display

interface "Frame\nInput" as FRAME_IN
interface "Gesture\nOutput" as GESTURE_OUT
interface "Cursor\nAction" as CURSOR_OUT
interface "Model\nCheckpoint" as MODEL_CP

FRAME_IN - WC
RTS - GESTURE_OUT
PYAGUI - CURSOR_OUT
MODEL - MODEL_CP

note right of RTS
  Orchestrates entire
  real-time pipeline
  30 FPS target
end note

note right of MODEL
  ViT-Tiny patch16-224
  ~5.7M parameters
  ImageNet pretrained
end note

note right of HD
  MediaPipe Hands
  Detects hand landmarks
  Extracts ROI bbox
end note

note right of DB
  Debounces gestures
  2-frame consistency
  200ms click cooldown
end note

note right of CS
  5-frame moving average
  Reduces hand tremor
end note

note right of TRAIN
  Phase 1: Freeze backbone
  Phase 2: Full fine-tuning
  AdamW + Cosine scheduler
end note

@enduml