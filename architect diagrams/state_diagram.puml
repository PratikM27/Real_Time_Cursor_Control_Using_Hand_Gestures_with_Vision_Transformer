@startuml RealTimeGestureControl_StateDiagram

[*] --> Initialization

state Initialization {
  [*] --> LoadConfig
  LoadConfig --> LoadModel
  LoadModel --> InitializeDetector
  InitializeDetector --> InitializeController
  InitializeController --> InitializeSmoother
  InitializeSmoother --> InitializeDebouncer
  InitializeDebouncer --> [*]
}

Initialization --> FrameCapture

state FrameCapture {
  [*] --> OpenWebcam
  OpenWebcam --> CaptureFrame
  CaptureFrame --> [*]
}

FrameCapture --> HandDetection

state HandDetection {
  [*] --> ProcessFrame
  ProcessFrame --> DetectLandmarks
  DetectLandmarks --> CheckHandFound
  
  CheckHandFound --> HandFound: Hand detected
  CheckHandFound --> NoHandFound: No hand
  
  HandFound --> ExtractROI
  ExtractROI --> ComputeBBox
  ComputeBBox --> ComputeCenter
  ComputeCenter --> ReturnResult
  ReturnResult --> [*]
  
  NoHandFound --> [*]
}

HandDetection --> PreprocessingDecision

state PreprocessingDecision <<choice>>
PreprocessingDecision --> SkipFrame: No hand
PreprocessingDecision --> ImagePreprocessing: Hand found

state ImagePreprocessing {
  [*] --> ExtractROI_Prep
  ExtractROI_Prep --> ConvertColor
  ConvertColor --> ResizeImage
  ResizeImage --> NormalizePixels
  NormalizePixels --> ToTensor
  ToTensor --> [*]
}

ImagePreprocessing --> Inference

state Inference {
  [*] --> LoadTensor
  LoadTensor --> PatchEmbedding
  PatchEmbedding --> PositionalEncoding
  PositionalEncoding --> TransformerEncoder
  TransformerEncoder --> ClassificationHead
  ClassificationHead --> ComputeProbs
  ComputeProbs --> OutputGesture
  OutputGesture --> [*]
}

Inference --> ConfidenceCheck

state ConfidenceCheck <<choice>>
ConfidenceCheck --> LowConfidence: confidence < 0.6
ConfidenceCheck --> HighConfidence: confidence >= 0.6

LowConfidence --> SkipFrame
HighConfidence --> Debouncing

state Debouncing {
  [*] --> CheckFrameConsistency
  CheckFrameConsistency --> CheckClickCooldown
  CheckClickCooldown --> ValidateThreshold
  
  ValidateThreshold --> DebounceValid: All checks pass
  ValidateThreshold --> DebounceInvalid: Any check fails
  
  DebounceValid --> [*]
  DebounceInvalid --> [*]
}

Debouncing --> DebounceDecision

state DebounceDecision <<choice>>
DebounceDecision --> SkipFrame: Invalid gesture
DebounceDecision --> Smoothing: Valid gesture

state Smoothing {
  [*] --> GetHandCenter
  GetHandCenter --> AppendToHistory
  AppendToHistory --> ComputeMovingAverage
  ComputeMovingAverage --> OutputSmoothed
  OutputSmoothed --> [*]
}

Smoothing --> ActionMapping

state ActionMapping {
  [*] --> CheckGestureType
  
  CheckGestureType --> OpenPalm: open_palm
  CheckGestureType --> IndexPoint: index_point
  CheckGestureType --> TwoFingersUp: two_fingers_up
  CheckGestureType --> Pinch: pinch
  CheckGestureType --> ThreeFingersUp: three_fingers_up
  CheckGestureType --> ThreeFingersDown: three_fingers_down
  CheckGestureType --> Fist: fist
  
  OpenPalm --> MoveCursor
  IndexPoint --> LeftClick
  TwoFingersUp --> RightClick
  Pinch --> StartDrag
  ThreeFingersUp --> ScrollUp
  ThreeFingersDown --> ScrollDown
  Fist --> Neutral
  
  MoveCursor --> [*]
  LeftClick --> [*]
  RightClick --> [*]
  StartDrag --> [*]
  ScrollUp --> [*]
  ScrollDown --> [*]
  Neutral --> [*]
}

ActionMapping --> UpdateFPS

state UpdateFPS {
  [*] --> IncrementFrameCount
  IncrementFrameCount --> CalculateFPS
  CalculateFPS --> [*]
}

UpdateFPS --> DebugRender

state DebugRender <<choice>>
DebugRender --> RenderDebug: show_debug = true
DebugRender --> SkipDebug: show_debug = false

state RenderDebug {
  [*] --> DrawOverlay
  DrawOverlay --> DrawGestureName
  DrawGestureName --> DrawConfidence
  DrawConfidence --> DrawFPS
  DrawFPS --> DrawLandmarks
  DrawLandmarks --> [*]
}

DebugRender --> DisplayFrame

state DisplayFrame {
  [*] --> RenderFrame
  RenderFrame --> ShowWindow
  ShowWindow --> [*]
}

DisplayFrame --> ExitCheck

state ExitCheck <<choice>>
ExitCheck --> FrameCapture: Continue
ExitCheck --> Cleanup: Quit signal

state Cleanup {
  [*] --> ReleaseCamera
  ReleaseCamera --> ReleaseResources
  ReleaseResources --> [*]
}

SkipFrame --> ExitCheck

state SkipFrame {
  [*] --> LogSkip
  LogSkip --> [*]
}

Cleanup --> [*]

note right of Initialization
  Initialize all components
  Load model checkpoint
  Setup detectors/controllers
end note

note right of HandDetection
  MediaPipe hand detection
  Extract landmarks & ROI
  Compute hand center
end note

note right of ImagePreprocessing
  Normalize input
  Resize to 224×224
  Create tensor
end note

note right of Inference
  ViT forward pass
  Get class probabilities
  Output gesture & confidence
end note

note right of ConfidenceCheck
  Filter low-confidence
  predictions (< 0.6)
end note

note right of Debouncing
  Ensure frame consistency
  Prevent accidental clicks
  Check cooldown timing
end note

note right of Smoothing
  5-frame moving average
  Reduce hand tremor
  Smooth cursor movement
end note

note right of ActionMapping
  Map gesture to action
  Execute cursor command
  Move, click, drag, scroll
end note

@enduml